# DESC: create an empty file or update timestamps

COMMAND_NAME = "touch"

import time
from datetime import datetime

async def run(message, session, args):
    OS = session.OS

    if not args:
        await message.channel.send("touch: missing file operand")
        return

    update_atime = True
    update_mtime = True
    create = True
    timestamp = None
    ref_file = None

    paths = []
    i = 0

    while i < len(args):
        a = args[i]

        if a == "-a":
            update_mtime = False
        elif a == "-m":
            update_atime = False
        elif a in ("-c", "--no-create"):
            create = False
        elif a == "-r":
            i += 1
            if i >= len(args):
                await message.channel.send("touch: option requires an argument -- r")
                return
            ref_file = args[i]
        elif a == "-t":
            i += 1
            if i >= len(args):
                await message.channel.send("touch: option requires an argument -- t")
                return
            timestamp = args[i]
        elif a.startswith("-"):
            await message.channel.send(f"touch: invalid option '{a}'")
            return
        else:
            paths.append(a)

        i += 1

    if not paths:
        await message.channel.send("touch: missing file operand")
        return
    def parse_timestamp(ts):
        if "." in ts:
            ts, sec = ts.split(".")
            sec = int(sec)
        else:
            sec = 0

        fmt = None
        if len(ts) == 12:
            fmt = "%Y%m%d%H%M"
        elif len(ts) == 10:
            fmt = "%y%m%d%H%M"
        elif len(ts) == 8:
            fmt = "%m%d%H%M"
            ts = str(datetime.now().year) + ts
            fmt = "%Y" + fmt
        else:
            return None

        dt = datetime.strptime(ts, fmt)
        return int(dt.timestamp()) + sec

    ref_atime = None
    ref_mtime = None

    if ref_file:
        if not ref_file.startswith("/"):
            ref_file = OS.join(OS.getCWD(), ref_file)
        ref_file = OS.normalize(ref_file)

        if not OS.exists(ref_file):
            await message.channel.send(f"touch: cannot stat '{ref_file}': No such file or directory")
            return

        rp = OS._real(ref_file)
        st = os.stat(rp)
        ref_atime = int(st.st_atime)
        ref_mtime = int(st.st_mtime)

    parsed_time = None
    if timestamp:
        parsed_time = parse_timestamp(timestamp)
        if parsed_time is None:
            await message.channel.send(f"touch: invalid date format '{timestamp}'")
            return

    for p in paths:
        if not p.startswith("/"):
            p = OS.join(OS.getCWD(), p)
        p = OS.normalize(p)

        if ref_file:
            atime = ref_atime
            mtime = ref_mtime
        elif parsed_time is not None:
            atime = parsed_time
            mtime = parsed_time
        else:
            now = int(time.time())
            atime = now
            mtime = now

        if not update_atime:
            if OS.exists(p):
                rp = OS._real(p)
                atime = int(os.stat(rp).st_atime)
        if not update_mtime:
            if OS.exists(p):
                rp = OS._real(p)
                mtime = int(os.stat(rp).st_mtime)

        try:
            OS.touch(p, atime=atime, mtime=mtime, create=create)
        except Exception as e:
            await message.channel.send(f"touch: cannot touch '{p}': {e}")
